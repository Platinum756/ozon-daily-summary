{
	"manifest_version": 3,
	"name": "Ozon PVZ Daily Summary",
	"version": "1.0.5",
	"description": "Automated log extraction for Turbo PVZ",
	
	"browser_specific_settings": {
		"gecko": {
			"id": "ozon-daily-summary-internal@krasnodontsev.com",
			"data_collection_permissions": {
				"required": [ "none" ]
			}
		}
	},
	
	"permissions": ["scripting", "tabs", "storage"],
	"host_permissions": ["https://turbo-pvz.ozon.ru/*"],
	"action": {
		"default_popup": "popup.html"
	}
}



